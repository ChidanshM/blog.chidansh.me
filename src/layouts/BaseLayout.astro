---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Chidansh Mehta's personal blog — writing, research, and ML." } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Chidansh</title>

  <!-- Oat CSS by knadh (https://github.com/knadh/oat) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/knadh/oat@master/oat.css" />

  <!-- Minimal overrides -->
  <style>
    :root {
      --font-size: 16px;
      --line-height: 1.65;
    }
    body {
      max-width: 680px;
      margin: 0 auto;
      padding: 2rem 1.25rem 4rem;
    }
    header {
      margin-bottom: 2.5rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid #e5e5e5;
      display: flex;
      align-items: baseline;
      gap: 2rem;
    }
    header a.site-name {
      font-weight: 600;
      text-decoration: none;
      font-size: 1rem;
    }
    nav {
      display: flex;
      gap: 1.25rem;
    }
    nav a {
      font-size: 0.9rem;
      text-decoration: none;
      color: #555;
    }
    nav a:hover, nav a.active {
      color: #111;
    }
    nav a.active {
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    footer {
      margin-top: 4rem;
      padding-top: 1rem;
      border-top: 1px solid #e5e5e5;
      font-size: 0.8rem;
      color: #888;
    }
    .post-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .post-list li {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.5rem 0;
      border-bottom: 1px solid #f0f0f0;
      gap: 1rem;
    }
    .post-list li:last-child {
      border-bottom: none;
    }
    .post-list .date {
      font-size: 0.82rem;
      color: #888;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .post-list a {
      text-decoration: none;
    }
    .post-list a:hover {
      text-decoration: underline;
    }
    .week-badge {
      display: inline-block;
      font-size: 0.75rem;
      background: #f5f5f5;
      border: 1px solid #e0e0e0;
      border-radius: 3px;
      padding: 0.1rem 0.4rem;
      margin-right: 0.4rem;
      color: #666;
    }
  </style>
</head>
<body>
  <header>
    <a class="site-name" href="/">chidansh</a>
    <nav>
      <a href="/writing" class={currentPath.startsWith('/writing') ? 'active' : ''}>writing</a>
      <a href="/research" class={currentPath.startsWith('/research') ? 'active' : ''}>research</a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <p>Chidansh Mehta · <a href="https://chidansh.com">chidansh.com</a> · <a href="mailto:me@chidansh.com">me@chidansh.com</a></p>
  </footer>
</body>
</html>
