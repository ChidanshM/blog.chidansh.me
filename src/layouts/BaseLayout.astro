---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Chidansh Mehta's personal blog — writing, research, and ML." } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Chidansh</title>

  <!-- Oat CSS by knadh (https://github.com/knadh/oat) -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/knadh/oat@master/oat.css" />

  <!-- Minimal overrides -->
  <style>
    :root {
      --font-size: 16px;
      --line-height: 1.65;
    }
    body {
      max-width: 680px;
      margin: 0 auto;
      padding: 2rem 1.25rem 4rem;
    }
    header {
      margin-bottom: 2.5rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid #e5e5e5;
      display: flex;
      align-items: baseline;
      gap: 2rem;
    }
    header a.site-name {
      font-weight: 600;
      text-decoration: none;
      font-size: 1rem;
    }
    nav {
      display: flex;
      gap: 1.25rem;
    }
    nav a {
      font-size: 0.9rem;
      text-decoration: none;
      color: #555;
    }
    nav a:hover, nav a.active {
      color: #111;
    }
    nav a.active {
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    footer {
      margin-top: 4rem;
      padding-top: 1rem;
      border-top: 1px solid #e5e5e5;
      font-size: 0.8rem;
      color: #888;
    }
    .post-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .post-list li {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      padding: 0.5rem 0;
      border-bottom: 1px solid #f0f0f0;
      gap: 1rem;
    }
    .post-list li:last-child {
      border-bottom: none;
    }
    .post-list .date {
      font-size: 0.82rem;
      color: #888;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .post-list a {
      text-decoration: none;
    }
    .post-list a:hover {
      text-decoration: underline;
    }
    .week-badge {
      display: inline-block;
      font-size: 0.75rem;
      background: #f5f5f5;
      border: 1px solid #e0e0e0;
      border-radius: 3px;
      padding: 0.1rem 0.4rem;
      margin-right: 0.4rem;
      color: #666;
    }
    .github-link {
      color: #888;
      text-decoration: none;
    }
    .github-link:hover {
      color: #111;
    }
  </style>
</head>
<body>
  <header>
    <a class="site-name" href="/">Chidansh</a>
    <nav>
      <a href="/writing" class={currentPath.startsWith('/writing') ? 'active' : ''}>writing</a>
      <a href="/research" class={currentPath.startsWith('/research') ? 'active' : ''}>research</a>
      <a href="/cis731" class={currentPath.startsWith('/cis731') ? 'active' : ''}>cis731</a>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer>
    <p>Chidansh Mehta · <a href="https://chidansh.com">chidansh.com</a> · <a href="mailto:me@chidansh.com">me@chidansh.com</a> · <a href="https://github.com/ChidanshM" title="GitHub" class="github-link"><svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" style="vertical-align: -2px;"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg></a></p>
  </footer>
</body>
</html>
